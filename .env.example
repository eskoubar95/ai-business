# Neon — pooled URL for Next.js runtime / `getDb()` (recommended).
DATABASE_URL=

# Dangerous — set to exactly `1` only when wiping local/demo app data (`npm run db:reset-app-data`). Never enable on production deployments.
ALLOW_APP_DATA_RESET=

# Per-user tenant wipe (`npm run db:reset-user-tenant-data`) — set to `1` with RESET_USER_EMAIL or RESET_USER_ID. Deletes sole-owned businesses for that user; unlinks shared businesses; clears user_settings. Never on production without intent.
ALLOW_USER_TENANT_RESET=
RESET_USER_EMAIL=
RESET_USER_ID=

# Neon — optional direct (non-pooled) hostname for Drizzle CLI only (`db:generate`, `db:migrate`, `db:studio`) if pooled URL fails. Copy from Neon Console → Connection details → direct.
DATABASE_DIRECT_URL=

# Neon Auth — from Neon Console: Project → Branch → Auth → Configuration (Auth URL).
NEON_AUTH_BASE_URL=

# Cookie signing secret for Neon Auth session helpers (32+ characters). Example: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Cursor Agent API key is stored per user in `user_settings` (encrypted with ENCRYPTION_KEY) via Settings / onboarding.

# Dev/test only (`NODE_ENV !== "production"`): skip calling Cursor.me during onboarding/API-key validation. Never enable in production.
CURSOR_API_VERIFY_SKIP=

# Local runner: prefers each business member’s stored key (earliest `user_businesses` membership with a key). Use env only as fallback.
# Optional fallback for the **local runner** when no linked user has a stored key.
CURSOR_API_KEY=

# AES-256 application encryption (MCP credentials + Cursor API key in user_settings). Must be exactly **64 hex characters** (32 bytes).
# Required for `tests/agents.spec.ts` when saving MCP credentials (`openssl rand -hex 32`).
# GitHub Actions: add the same value as repository secret `ENCRYPTION_KEY` — without it, agents E2E fails on MCP install.
ENCRYPTION_KEY=

# Notion integration token (optional; server-only).
NOTION_API_TOKEN=

# Webhook HMAC signing (incoming webhook verification). Use a long random secret; never commit the real value.
WEBHOOK_SECRET=

# Optional — GitHub API token for `installSkillFromGitHub` rate limits (server-only).
GITHUB_TOKEN=

# Optional — public site URL for webhook endpoint display in Settings (`getPublicOrigin` fallback when request headers are unavailable).
NEXT_PUBLIC_APP_URL=

# Sentry (optional) — set DSN to enable error + performance reporting. Use `NEXT_PUBLIC_SENTRY_DSN` for browser + server; optional `SENTRY_DSN` server-only override.
# Create a Next.js project in Sentry and paste the DSN. CI: add `SENTRY_AUTH_TOKEN`, `SENTRY_ORG`, `SENTRY_PROJECT` for source maps (see Sentry docs).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
# Sample rate for performance traces (0–1). Default in code: 0.1
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Playwright — Grill-Me E2E (`tests/grill-me.spec.ts`). Both required for that spec to run; needs DATABASE_URL + Neon Auth env so the app can sign in and persist sessions.
# GitHub Actions: mirror DATABASE_URL, NEON_AUTH_*, E2E_EMAIL, E2E_PASSWORD as repository secrets (see README.md → CI).
E2E_EMAIL=
E2E_PASSWORD=

# Playwright helper for `tests/approvals.spec.ts` — protects POST `/api/e2e/seed-approval` (non-production only).
# GitHub Actions: optional secret `E2E_SETUP_SECRET`; if unset, approvals E2E is skipped (agents/grill-me still run).
E2E_SETUP_SECRET=
# Deterministic Grill-Me assistant replies without Cursor CLI (Playwright webServer sets this to `1` by default). Omit for normal local dev.
# GRILL_ME_E2E_MOCK=

# Grill-Me — Cursor Agent runtime (applied to onboarding + SSE routes)
# Silent Prompt 1 (reasoning) — optional dedicated model; falls back to `CURSOR_GRILL_ME_MODEL_*` chain in code when unset.
CURSOR_GRILL_REASONING_MODEL_ID=
CURSOR_GRILL_REASONING_MODEL_PARAMS_JSON=

# Prompt 2 (chat interview) — when unset, model defaults to composer-2 in SDK wrapper; set to override for interviews.
CURSOR_GRILL_ME_MODEL_ID=
# Optional JSON: [{"id":"reasoning_effort","value":"high"}] — valid keys come from Cursor.models.list for your key.
CURSOR_GRILL_ME_MODEL_PARAMS_JSON=
# Comma-separated layers: project | user | team | mdm | plugins | all — unset ⇒ `project` (loads repo `.cursor` rules/skills)
# Set to `none` or `off` to disable all ambient Cursor settings for Grill-Me.
CURSOR_GRILL_ME_SETTING_SOURCES=
# Repo-relative Markdown injected under “Attached skill guides” — comma-separated. Unset ⇒ `.agents/skills/grill-me-onboarding/SKILL.md` when the file exists.
GRILL_ME_SKILL_PATHS=
