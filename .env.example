# Neon — pooled connection string for Next.js serverless/runtime.
DATABASE_URL=

# Neon Auth server URL from Neon Console → Branch → Auth.
NEON_AUTH_BASE_URL=

# 32+ character secret for session cookie signing (e.g. openssl rand -base64 32).
NEON_AUTH_COOKIE_SECRET=

# AES-256 key for application-side encryption (e.g. MCP credentials). 32 raw bytes encoded as base64 in app code.
ENCRYPTION_KEY=

# Notion integration (optional; token only on server).
NOTION_API_TOKEN=
