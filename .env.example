# Neon ‚Äî pooled URL for Next.js runtime / `getDb()` (recommended).
DATABASE_URL=

# Dangerous ‚Äî set to exactly `1` only when wiping local/demo app data (`npm run db:reset-app-data`). Never enable on production deployments.
ALLOW_APP_DATA_RESET=

# Neon ‚Äî optional direct (non-pooled) hostname for Drizzle CLI only (`db:generate`, `db:migrate`, `db:studio`) if pooled URL fails. Copy from Neon Console ‚Üí Connection details ‚Üí direct.
DATABASE_DIRECT_URL=

# Neon Auth ‚Äî from Neon Console: Project ‚Üí Branch ‚Üí Auth ‚Üí Configuration (Auth URL).
NEON_AUTH_BASE_URL=

# Cookie signing secret for Neon Auth session helpers (32+ characters). Example: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# Cursor Agent API key is stored per user in `user_settings` (encrypted with ENCRYPTION_KEY) via the Settings page ‚Äî not a global env var.

# Cursor API key used only by the **local runner** (`npm run runner`, `npm run dev:full`). This is separate from the encrypted key in Settings UI.
CURSOR_API_KEY=

# AES-256 application encryption (MCP credentials + Cursor API key in user_settings). Must be exactly **64 hex characters** (32 bytes).
# Required for `tests/agents.spec.ts` when saving MCP credentials (`openssl rand -hex 32`).
# GitHub Actions: add the same value as repository secret `ENCRYPTION_KEY` ‚Äî without it, agents E2E fails on MCP install.
ENCRYPTION_KEY=

# Notion integration token (optional; server-only).
NOTION_API_TOKEN=

# Webhook HMAC signing (incoming webhook verification). Use a long random secret; never commit the real value.
WEBHOOK_SECRET=

# Optional ‚Äî GitHub API token for `installSkillFromGitHub` rate limits (server-only).
GITHUB_TOKEN=

# Optional ‚Äî public site URL for webhook endpoint display in Settings (`getPublicOrigin` fallback when request headers are unavailable).
NEXT_PUBLIC_APP_URL=

# Playwright ‚Äî Grill-Me E2E (`tests/grill-me.spec.ts`). Both required for that spec to run; needs DATABASE_URL + Neon Auth env so the app can sign in and persist sessions.
# GitHub Actions: mirror DATABASE_URL, NEON_AUTH_*, E2E_EMAIL, E2E_PASSWORD as repository secrets (see README.md ‚Üí CI).
E2E_EMAIL=
E2E_PASSWORD=

# Playwright helper for `tests/approvals.spec.ts` ‚Äî protects POST `/api/e2e/seed-approval` (non-production only).
# GitHub Actions: optional secret `E2E_SETUP_SECRET`; if unset, approvals E2E is skipped (agents/grill-me still run).
E2E_SETUP_SECRET=
# Deterministic Grill-Me assistant replies without Cursor CLI (Playwright webServer sets this to 1 by default). Omit for normal local dev.
# GRILL_ME_E2E_MOCK=
