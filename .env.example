# Neon — pooled URL for Next.js runtime / `getDb()` (recommended).
DATABASE_URL=

# Neon — optional direct (non-pooled) hostname for Drizzle CLI only (`db:generate`, `db:migrate`, `db:studio`) if pooled URL fails. Copy from Neon Console → Connection details → direct.
DATABASE_DIRECT_URL=

# Neon Auth — from Neon Console: Project → Branch → Auth → Configuration (Auth URL).
NEON_AUTH_BASE_URL=

# Cookie signing secret for Neon Auth session helpers (32+ characters). Example: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# AES-256 application encryption (MCP credentials). Must be exactly **64 hex characters** (32 bytes).
ENCRYPTION_KEY=

# Notion integration token (optional; server-only).
NOTION_API_TOKEN=

# Playwright — Grill-Me E2E (`tests/grill-me.spec.ts`). Both required for that spec to run; needs DATABASE_URL + Neon Auth env so the app can sign in and persist sessions.
# GitHub Actions: mirror DATABASE_URL, NEON_AUTH_*, E2E_EMAIL, E2E_PASSWORD as repository secrets (see README.md → CI).
E2E_EMAIL=
E2E_PASSWORD=

# Deterministic Grill-Me assistant replies without Cursor CLI (Playwright webServer sets this to 1 by default). Omit for normal local dev.
# GRILL_ME_E2E_MOCK=
